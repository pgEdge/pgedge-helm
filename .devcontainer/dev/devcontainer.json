{
  "name": "pgEdge Helm Chart Development",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/go:1": {}
  },
  "postCreateCommand": "if [ -f Chart.yaml ]; then helm dependency update; else echo 'No Chart.yaml in workspace root; skipping helm dependency update.'; fi",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "golang.go",
        "redhat.vscode-yaml"
      ]
    }
  }
}
